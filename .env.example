# RepoPilot AI configuration template.
# Keep real secrets out of source control. Copy to `.env` for local service wiring
# and local-only placeholders; prefer the dashboard/runtime secret store for live
# GitHub, OAuth, session, and model credentials.

REPOPILOT_ENV=local
# `oss-demo` keeps local/demo readiness honest without requiring live writes.
# Use `production` only for credentialed releases; it blocks local-record write mode.
REPOPILOT_RELEASE_PROFILE=oss-demo

# Released-image install path. Source builds ignore these values; GHCR Compose
# uses them to pull released images without rebuilding from local source.
REPOPILOT_IMAGE_TAG=latest
REPOPILOT_API_IMAGE=
REPOPILOT_WEB_IMAGE=
REPOPILOT_SANDBOX_IMAGE=

# Required by docker-compose.yml. Run `make init-local-env` to fill local-only
# values in `.env`; use a restricted `.env` outside source control or a secret
# manager for live values.
POSTGRES_PASSWORD=
REDIS_PASSWORD=

DATABASE_URL=postgresql+asyncpg://repopilot:${POSTGRES_PASSWORD}@postgres:5432/repopilot
ALEMBIC_DATABASE_URL=postgresql+psycopg://repopilot:${POSTGRES_PASSWORD}@postgres:5432/repopilot
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# GitHub App webhook verification. Save the live value through Settings or the
# runtime secret store for credentialed smoke tests.
GITHUB_WEBHOOK_SECRET=

# GitHub App credential placeholders. Save live values through Settings or the
# runtime secret store before enabling real GitHub writes.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_INSTALLATION_ID=
# Preferred direct-key name. Do not commit private keys.
GITHUB_APP_PRIVATE_KEY=
# Backward-compatible alias accepted by older scripts.
GITHUB_PRIVATE_KEY=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_APP_VERIFIED_AT=
GITHUB_APP_VERIFIED_INSTALLATION_ID=
GITHUB_WRITE_SMOKE_VERIFIED_AT=

# GitHub OAuth/session placeholders for dashboard user identity. Save live
# OAuth and session secrets through Settings or the runtime secret store.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8000/auth/github/callback
WEB_APP_URL=http://localhost:3001
SESSION_SECRET_KEY=
DEV_HEADER_AUTH_ENABLED=false
# Docker Compose mounts ./.local/repopilot-secrets to this in-container path.
# Leave empty for local mode; set through a secret manager outside local demos.
REPOPILOT_RUNTIME_SECRETS_KEY=
REPOPILOT_RUNTIME_SECRETS_KEY_PATH=/home/appuser/.repopilot/runtime-secrets.key
REPOPILOT_RUNTIME_SECRETS_STORE_PATH=/home/appuser/.repopilot/runtime-secrets.json

# Keep false until the GitHub App is installed on a demo repo and credentials are loaded.
GITHUB_WRITES_ENABLED=false
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEB_BASE_URL=https://github.com

# Model gateway. `mock` keeps tests deterministic; save live provider keys through
# Settings or the runtime secret store for real planning/code generation.
MODEL_PROVIDER=mock
MODEL_NAME=mock-planner
MODEL_API_KEY=
MODEL_REQUEST_TIMEOUT_SECONDS=60
MODEL_REQUEST_MAX_RETRIES=1
MODEL_REQUEST_RETRY_BACKOFF_SECONDS=0.5
# Local mode may use deterministic fallback for offline tests. Non-local
# deployments should leave this false so provider failures fail closed.
ALLOW_MODEL_FALLBACK=false
MODEL_PROVIDER_VERIFIED_AT=
MODEL_PROVIDER_VERIFIED_MODEL=
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-embedding
EMBEDDING_DIMENSIONS=1536
# Explicit opt-in before repository paths/source chunks can be sent to an
# external embedding provider. Keep false for private source that must stay local.
EMBEDDING_SOURCE_TRANSFER_ENABLED=false
REPOPILOT_MAX_COST_PER_RUN=5.00
REPOPILOT_MAX_TOKENS_PER_RUN=250000
REPOPILOT_MAX_LLM_CALLS_PER_RUN=40
REPOPILOT_MAX_AGENT_RETRIES=3
REPOPILOT_RATE_LIMIT_WINDOW_SECONDS=60
REPOPILOT_RATE_LIMIT_STATE_CHANGES_PER_MINUTE=60
REPOPILOT_RATE_LIMIT_EXPENSIVE_PER_MINUTE=20

# Sandbox runner.
REPOPILOT_REPOSITORY_WORKSPACE_ROOT=/tmp/repopilot-repositories
SANDBOX_BACKEND=docker
SANDBOX_DOCKER_IMAGE=repopilot-sandbox:local
SANDBOX_MEMORY_LIMIT=1g
SANDBOX_CPUS=1.0
SANDBOX_PIDS_LIMIT=256
WORKSPACE_CLEANUP_MAX_AGE_SECONDS=86400
WORKSPACE_CLEANUP_INTERVAL_SECONDS=3600
REPOPILOT_ARTIFACT_STORE_ROOT=/tmp/repopilot-artifacts
REPOPILOT_ARTIFACT_INLINE_MAX_BYTES=12000
REPOPILOT_ARTIFACT_RETENTION_MAX_AGE_SECONDS=2592000
REPOPILOT_ARTIFACT_RETENTION_INTERVAL_SECONDS=86400
REPOPILOT_ARTIFACT_RETENTION_DRY_RUN=true

# Observability and security-tool placeholders.
ENABLE_OTEL=true
OTEL_EXPORTER_OTLP_ENDPOINT=
SEMGREP_ENABLED=true
CODEQL_ENABLED=true
DEPENDENCY_AUDIT_ENABLED=true
